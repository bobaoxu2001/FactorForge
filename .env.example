# Optional real-data provider keys. Yahoo Finance works without a key as the
# default. If every real-data provider fails, the app uses deterministic
# fallback/demo data and labels it in the UI.
POLYGON_API_KEY=
ALPHA_VANTAGE_API_KEY=

# Logging
LOG_LEVEL=info  # debug | info | warn | error

# Optional LLM provider for AI research memos and strategy thesis.
# Without a key the platform falls back to the deterministic template.
DEEPSEEK_API_KEY=

# Required for public production deployments. Iron-session cookie signing key;
# use a random value of at least 32 characters. Do not expose it to the browser.
# Local development can boot without it, but Vercel/production should set it.
SESSION_PASSWORD=

# Public origin used for absolute metadata / OpenGraph URLs. Defaults to
# http://localhost:3000 for local development.
SITE_URL=

# Optional fetch tuning. Lower this if a host or provider throttles build-time
# data requests.
MARKET_FETCH_CONCURRENCY=4

# Optional annual risk-free rate used by metric helpers. Defaults to 0.
RISK_FREE_RATE=0

# Optional distributed rate-limit store. Without it, auth throttling is
# per-process — fine for a single long-lived Node server, but under multiple
# instances each keeps its own counters, so an attacker gets N× the attempts.
# Set these to share one counter across the fleet (Upstash Redis or Vercel KV;
# both speak the same REST API). Vercel-KV's KV_REST_API_URL / KV_REST_API_TOKEN
# are also accepted.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
KV_REST_API_URL=
KV_REST_API_TOKEN=
