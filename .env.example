# Real-data provider keys. Yahoo Finance works without a key as the default.
# Set the others to add second-tier real data: the composite provider tries
# yahoo → polygon → alphaVantage → synthetic fallback in that order.
POLYGON_API_KEY=
ALPHA_VANTAGE_API_KEY=

# Logging
LOG_LEVEL=info  # debug | info | warn | error

# LLM provider for AI Research Memo and strategy thesis.
# Without a key the platform falls back to the deterministic template.
DEEPSEEK_API_KEY=

# Iron-session cookie signing key. Must be ≥32 chars random in production.
# The app boots with a dev default if this is unset (dev convenience).
SESSION_PASSWORD=

# Public origin used for absolute metadata / OpenGraph URLs. Defaults to
# http://localhost:3000 for local development.
SITE_URL=
